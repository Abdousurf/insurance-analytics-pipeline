{
  "expectation_suite_name": "claims_quality_suite",
  "ge_cloud_id": null,
  "data_asset_type": null,
  "meta": {
    "great_expectations_version": "0.18.8",
    "description": "Validations actuarielles sur les sinistres transformés"
  },
  "expectations": [
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "claim_id" },
      "meta": { "notes": "Chaque sinistre doit avoir un identifiant" }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "claim_id" },
      "meta": { "notes": "Pas de doublons dans les sinistres" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "policy_id" },
      "meta": { "notes": "Chaque sinistre doit être rattaché à une police" }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "lob",
        "value_set": ["Auto", "Home", "Liability", "Health"]
      },
      "meta": { "notes": "Branches d'assurance autorisées" }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "status",
        "value_set": ["Open", "Closed"]
      },
      "meta": { "notes": "Statut du sinistre — ouvert ou clos" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "ultimate_cost",
        "min_value": 0,
        "strict_min": true
      },
      "meta": { "notes": "Le coût ultime doit être strictement positif" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "paid_amount",
        "min_value": 0
      },
      "meta": { "notes": "Le montant payé ne peut pas être négatif" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "reserve",
        "min_value": 0
      },
      "meta": { "notes": "La réserve ne peut pas être négative" }
    },
    {
      "expectation_type": "expect_column_pair_values_a_to_be_greater_than_b",
      "kwargs": {
        "column_A": "reporting_date",
        "column_B": "claim_date",
        "or_equal": true
      },
      "meta": { "notes": "La date de déclaration doit être >= date de survenance" }
    }
  ]
}
